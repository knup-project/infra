# Copy to terraform.tfvars and fill in.
# terraform.tfvars is gitignored.

tenancy_ocid     = "ocid1.tenancy.oc1..REPLACE"
user_ocid        = "ocid1.user.oc1..REPLACE"
fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "ap-chuncheon-1"
compartment_ocid = "ocid1.compartment.oc1..REPLACE"

ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Override only if your local SSH key isn't at ~/.ssh/id_ed25519.
# ssh_private_key_path = "~/.ssh/knup_oci"

# State backend (S3-compatible OCI Object Storage) auth is passed via env, not
# here: export AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (an OCI Customer Secret
# Key) and AWS_REGION before `tofu init`. DB credentials live on the VM in
# /opt/knup/.env (see vm/.env.example), not in Terraform.
