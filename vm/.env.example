# Copy to /opt/knup/.env on the VM and fill in. Never commit the real file.
# Consumed by vm/docker-compose.yml.

DB_USER=knup
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-strong-root-password

# Google Gemini API key (https://aistudio.google.com/apikey) for AI quiz generation.
# Leave empty to disable AI; AI endpoints then return AI_SERVICE_ERROR.
GEMINI_API_KEY=

# Grafana Cloud (Free) — the `alloy` service (profile: monitoring) remote-writes
# the backend's Actuator metrics here. Get these from Grafana Cloud →
# Connections → Prometheus (Hosted), and a token with metrics:write scope.
# Only needed when running `docker compose --profile monitoring up -d alloy`.
GRAFANA_CLOUD_PROM_URL=
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_API_KEY=

