# Copy to /opt/knup/.env on the VM and fill in. Never commit the real file.
# Consumed by vm/docker-compose.yml.

DB_USER=knup
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-strong-root-password

# Google Gemini API key (https://aistudio.google.com/apikey) for AI quiz generation.
# Leave empty to disable AI; AI endpoints then return AI_SERVICE_ERROR.
GEMINI_API_KEY=

# Grafana Cloud (Free) — the `alloy` service (profile: monitoring) ships:
#   - Prometheus metrics from the backend's /actuator/prometheus
#   - Loki logs from every running container's stdout/stderr
# Only needed when running `docker compose --profile monitoring up -d alloy`.
#
# Get the values from Grafana Cloud → Connections:
#   Prometheus (Hosted) → URL + Username
#   Loki (Hosted)       → URL + Username
# Issue one access policy token (Administration → Cloud access policies) with
# both metrics:write and logs:write scopes — it goes into GRAFANA_CLOUD_API_KEY.
GRAFANA_CLOUD_PROM_URL=
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_API_KEY=

